# Copy to .env and adjust. NEVER commit .env.
# All variables are IDC_-prefixed so other projects' env vars (DATABASE_URL etc.)
# on this machine never leak into this app.
IDC_APP_NAME=internal-dev-coordinator
IDC_ENVIRONMENT=local
IDC_DATABASE_URL=postgresql+psycopg://idc:idc@localhost:5455/idc
IDC_AUTH_MODE=dev
IDC_DEV_DEFAULT_USER_EMAIL=gregory.panagary@cwseychelles.com
# Entra/OIDC (IDC_AUTH_MODE=entra) - see docs/DEPLOYMENT.md section 3:
# IDC_ENTRA_TENANT_ID=
# IDC_ENTRA_CLIENT_ID=
IDC_FRESHNESS_THRESHOLD_DAYS=14
IDC_AI_PROVIDER=disabled
IDC_AI_MODEL=
# AI provider API key is read from the environment at runtime (T8+), never stored in DB.
# IDC_AI_API_KEY=
#
# To enable real AI tailoring/summary output via OpenRouter (approved 2026-07-13):
# IDC_AI_PROVIDER=openrouter
# IDC_AI_MODEL=nvidia/nemotron-nano-9b-v2:free   # free-tier models come and go; check GET https://openrouter.ai/api/v1/models
# IDC_AI_API_KEY=sk-or-...   # from https://openrouter.ai/keys - never commit this
#
# GitHub READ integration (Phase 4) - strictly read-only repo signals.
IDC_GITHUB_PROVIDER=disabled
# IDC_GITHUB_PROVIDER=github
# IDC_GITHUB_TOKEN=github_pat_...   # fine-grained PAT, read-only contents/metadata - never commit this
# IDC_GITHUB_API_BASE=https://api.github.com
#
# In-app integration settings (Settings page) override the env values above.
# Credentials saved in-app are encrypted at rest with this Fernet key:
# IDC_SECRET_KEY=   # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Active repo tracking (background poller writing repo_snapshots):
IDC_ENABLE_BACKGROUND_POLLING=true
IDC_REPO_POLL_INTERVAL_MINUTES=30