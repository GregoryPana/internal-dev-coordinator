# Copy to .env and adjust. NEVER commit .env.
# All variables are IDC_-prefixed so other projects' env vars (DATABASE_URL etc.)
# on this machine never leak into this app.
IDC_APP_NAME=internal-dev-coordinator
IDC_ENVIRONMENT=local
IDC_DATABASE_URL=postgresql+psycopg://idc:idc@localhost:5455/idc
IDC_AUTH_MODE=dev
IDC_DEV_DEFAULT_USER_EMAIL=gregory.panagary@cwseychelles.com
IDC_FRESHNESS_THRESHOLD_DAYS=14
IDC_AI_PROVIDER=disabled
IDC_AI_MODEL=
# AI provider API key is read from the environment at runtime (T8+), never stored in DB.
# IDC_AI_API_KEY=
#
# To enable real AI tailoring/summary output via OpenRouter (approved 2026-07-13):
# IDC_AI_PROVIDER=openrouter
# IDC_AI_MODEL=google/gemma-4-31b-it:free   # free-tier models 429 intermittently; swap if needed
# IDC_AI_API_KEY=sk-or-...   # from https://openrouter.ai/keys - never commit this